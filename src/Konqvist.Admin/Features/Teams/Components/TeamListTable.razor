@using Konqvist.Admin.Features.Teams
@using Konqvist.Infrastructure.Entities.Enums
@using Microsoft.JSInterop
@using MudBlazor

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">Configured teams</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@Teams.Count total</MudText>
    </MudStack>

    @if (Teams.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No teams configured yet.</MudAlert>
    }
    else
    {
        <MudTable Items="Teams" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Color</MudTh>
                <MudTh>Runner token</MudTh>
                <MudTh>Team Captain token</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Color">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudAvatar Size="Size.Small" Style="@($"background-color:{context.Color};")" />
                        <MudText Typo="Typo.body2">@context.Color</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Runner token">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudTextField T="string" Value="@context.RunnerToken" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTooltip Text="Copy runner token">
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@IsBusy"
                                           OnClick="() => CopyRunnerTokenAsync(context.RunnerToken)" />
                        </MudTooltip>
                        <MudTooltip Text="Regenerate runner token">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Disabled="@IsBusy"
                                           OnClick="() => OnRegenerateToken(context, PlayerRole.Runner)" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Team Captain token">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudTextField T="string" Value="@context.TeamCaptainToken" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTooltip Text="Copy team captain token">
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@IsBusy"
                                           OnClick="() => CopyTeamCaptainTokenAsync(context.TeamCaptainToken)" />
                        </MudTooltip>
                        <MudTooltip Text="Regenerate team captain token">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Disabled="@IsBusy"
                                           OnClick="() => OnRegenerateToken(context, PlayerRole.TeamLeader)" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                        <MudTooltip Text="Edit team">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(IsBusy || EditingTeamId == context.Id)"
                                           OnClick="() => OnEditTeam(context)" />
                        </MudTooltip>
                        <MudTooltip Text="Delete team">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Variant="Variant.Text"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Disabled="@IsBusy"
                                           OnClick="() => OnDeleteTeam(context.Id)" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<TeamTemplateListItem> Teams { get; set; } = [];

    [Parameter]
    public int? EditingTeamId { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter, EditorRequired]
    public Func<TeamTemplateListItem, Task> OnEditTeam { get; set; } = null!;

    [Parameter, EditorRequired]
    public Func<int, Task> OnDeleteTeam { get; set; } = null!;

    [Parameter, EditorRequired]
    public Func<TeamTemplateListItem, PlayerRole, Task> OnRegenerateToken { get; set; } = null!;

    [Inject]
    private IJSRuntime JsRuntime { get; set; } = null!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = null!;

    private async Task CopyTokenAsync(string token, string roleLabel)
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", token);
            Snackbar.Add($"{roleLabel} token copied.", Severity.Success);
        }
        catch (JSException)
        {
            Snackbar.Add($"Could not copy {roleLabel} token.", Severity.Warning);
        }
    }

    private Task CopyRunnerTokenAsync(string token) => CopyTokenAsync(token, "Runner");

    private Task CopyTeamCaptainTokenAsync(string token) => CopyTokenAsync(token, "Team Captain");
}
