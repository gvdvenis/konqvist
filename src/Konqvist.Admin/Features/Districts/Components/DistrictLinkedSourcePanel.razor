@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Linked source</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (_isCollapsed)
                {
                    <MudTooltip Text="Edit linked source">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Class="grid-square-action"
                                   Disabled="@IsBusy"
                                   OnClick="HandleExpand">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" />
                        </MudButton>
                    </MudTooltip>
                }
                else if (ShowBackToChoices)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Disabled="@IsBusy"
                               OnClick="OnBackToChoices">
                        Back to choices
                    </MudButton>
                }
            </MudStack>
        </MudStack>
        @if (_isCollapsed)
        {
            <MudText Typo="Typo.body2" Class="admin-muted-text">@SourceUrlInput</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="admin-muted-text">
                Enter an HTTPS KML/KMZ URL, then import districts from that source.
            </MudText>
            <MudTextField T="string"
                          Label="Source URL"
                          Placeholder="https://example.com/districts.kml"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Disabled="@IsBusy"
                          OnBlur="HandleSourceUrlBlur"
                          Value="@SourceUrlInput"
                          ValueChanged="HandleSourceUrlChanged" 
                          Clearable="true"
                          />
            <MudStack Row="true" Spacing="2" >
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudDownload"
                           Disabled="@(IsBusy || string.IsNullOrWhiteSpace(SourceUrlInput))"
                           OnClick="OnRefreshFromSource">
                    Import districts
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Color="Color.Secondary"
                           Disabled="@IsBusy"
                           OnClick="HandleCloseAsync">
                    Close
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string SourceUrlInput { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SourceUrlInputChanged { get; set; }

    [Parameter]
    public EventCallback OnRefreshFromSource { get; set; }

    [Parameter]
    public bool ShowBackToChoices { get; set; }

    [Parameter]
    public bool IsSourceLocked { get; set; }

    [Parameter]
    public EventCallback OnBackToChoices { get; set; }

    [Parameter]
    public EventCallback OnEmptyInputExit { get; set; }

    private bool _isCollapsed;
    private bool _isCollapseStateInitialized;
    private bool _lastSourceLocked;

    protected override void OnParametersSet()
    {
        if (!_isCollapseStateInitialized || _lastSourceLocked != IsSourceLocked)
        {
            _isCollapsed = IsSourceLocked;
            _isCollapseStateInitialized = true;
            _lastSourceLocked = IsSourceLocked;
        }
    }

    private async Task HandleSourceUrlChanged(string? value)
    {
        SourceUrlInput = value ?? string.Empty;
        await SourceUrlInputChanged.InvokeAsync(SourceUrlInput);
    }

    private async Task HandleSourceUrlBlur(FocusEventArgs _)
    {
        if (!string.IsNullOrWhiteSpace(SourceUrlInput))
        {
            return;
        }

        await OnEmptyInputExit.InvokeAsync();
    }

    private void HandleExpand()
    {
        _isCollapsed = false;
    }

    private async Task HandleCloseAsync()
    {
        if (!string.IsNullOrWhiteSpace(SourceUrlInput))
        {
            _isCollapsed = true;
            return;
        }

        await OnEmptyInputExit.InvokeAsync();
    }
}
