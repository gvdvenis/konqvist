@page "/logout"
@page "/team/{Name}/logout"
@using Konqvist.Client.Features.Auth
@inject LoginApiClient LoginApiClient
@inject NavigationManager NavigationManager
@inject ClientAuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Logout</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h6" Class="mb-2">Logging you out…</MudText>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@ErrorMessage</MudAlert>
            <MudButton Variant="Variant.Outlined" OnClick="LogoutAsync">Retry</MudButton>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string? Name { get; set; }

    private string? ErrorMessage { get; set; }

    protected override Task OnParametersSetAsync() => LogoutAsync();

    private async Task LogoutAsync()
    {
        ErrorMessage = null;

        var result = await LoginApiClient.LogoutAsync(Name);
        if (!result.IsSuccess)
        {
            ErrorMessage = result.ErrorMessage;
            return;
        }

        AuthenticationStateProvider.RefreshAuthenticationState();
        var target = string.IsNullOrWhiteSpace(Name)
            ? "/login"
            : $"/team/{Uri.EscapeDataString(Name)}";
        NavigationManager.NavigateTo(target, replace: true);
    }
}
