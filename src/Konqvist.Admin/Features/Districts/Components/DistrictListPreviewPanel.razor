@using Konqvist.Admin.Features.Districts
@using MudBlazor

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">District list</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@Districts.Count total</MudText>
    </MudStack>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
        <MudNumericField T="int"
                         Label="Min"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="0"
                         Disabled="@IsBusy"
                         Value="RandomizeMin"
                         ValueChanged="HandleRandomizeMinChanged" />
        <MudNumericField T="int"
                         Label="Max"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="0"
                         Disabled="@IsBusy"
                         Value="RandomizeMax"
                         ValueChanged="HandleRandomizeMaxChanged" />
       
        <MudTooltip Text="Randomize resources">
            <MudIconButton Icon="@Icons.Material.Filled.Casino"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Medium"
                           Disabled="@IsBusy"
                           OnClick="HandleRandomizeResourcesAsync" />
        </MudTooltip>
    </MudStack>

    @if (Districts.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No districts available yet.</MudAlert>
    }
    else
    {
        var editingDistrict = EditingDistrict;
        @if (editingDistrict is not null)
        {
            <MudPaper Outlined="true" Class="pa-3 mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">Edit @editingDistrict.Name</MudText>
                    <MudTooltip Text="Close editor">
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Variant="Variant.Text"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       Disabled="@IsBusy"
                                       OnClick="HandleCloseEditorAsync" />
                    </MudTooltip>
                </MudStack>
                <MudGrid>
                    <MudItem xs="6" md="4">
                        <MudNumericField T="int"
                                         Label="Gold"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Disabled="@IsBusy"
                                         Value="EditorInput.Gold"
                                         ValueChanged="value => UpdateEditor(editor => editor.Gold = value)" />
                    </MudItem>
                    <MudItem xs="6" md="4">
                        <MudNumericField T="int"
                                         Label="Voters"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Disabled="@IsBusy"
                                         Value="EditorInput.Voters"
                                         ValueChanged="value => UpdateEditor(editor => editor.Voters = value)" />
                    </MudItem>
                    <MudItem xs="6" md="4">
                        <MudNumericField T="int"
                                         Label="Likes"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Disabled="@IsBusy"
                                         Value="EditorInput.Likes"
                                         ValueChanged="value => UpdateEditor(editor => editor.Likes = value)" />
                    </MudItem>
                    <MudItem xs="6" md="4">
                        <MudNumericField T="int"
                                         Label="Oil"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Disabled="@IsBusy"
                                         Value="EditorInput.Oil"
                                         ValueChanged="value => UpdateEditor(editor => editor.Oil = value)" />
                    </MudItem>
                    <MudItem xs="6" md="8">
                        <MudNumericField T="double"
                                         Label="Trigger radius (m)"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="5"
                                         Disabled="@IsBusy"
                                         Value="EditorInput.TriggerRadiusMeters"
                                         ValueChanged="value => UpdateEditor(editor => editor.TriggerRadiusMeters = value)" />
                    </MudItem>
                </MudGrid>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@IsBusy"
                               OnClick="HandleSaveSelectedDistrictAsync">
                        Save
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               Disabled="@IsBusy"
                               OnClick="HandleCloseEditorAsync">
                        Close
                    </MudButton>
                </MudStack>
            </MudPaper>
        }

        <MudTable T="DistrictPreviewItem"
                  Items="Districts"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Class="district-preview-table"
                  RowClassFunc="GetRowClass"
                  OnRowClick="HandleRowClick"
                  >
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh Style="text-align: center;">Gold</MudTh>
                <MudTh Style="text-align: center;">Voters</MudTh>
                <MudTh Style="text-align: center;">Likes</MudTh>
                <MudTh Style="text-align: center;">Oil</MudTh>
                <MudTh Style="text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Gold" Style="text-align: center;">@context.Gold</MudTd>
                <MudTd DataLabel="Voters" Style="text-align: center;">@context.Voters</MudTd>
                <MudTd DataLabel="Likes" Style="text-align: center;">@context.Likes</MudTd>
                <MudTd DataLabel="Oil" Style="text-align: center;">@context.Oil</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Edit district resources">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@IsBusy"
                                       OnClick="() => HandleEditDistrictResourcesAsync(context.Id)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<DistrictPreviewItem> Districts { get; set; } = [];

    [Parameter]
    public int? SelectedDistrictId { get; set; }

    [Parameter]
    public EventCallback<int> OnDistrictSelected { get; set; }

    [Parameter]
    public int? EditingDistrictId { get; set; }

    [Parameter, EditorRequired]
    public DistrictResourceEditorInput EditorInput { get; set; } = null!;

    [Parameter]
    public EventCallback<DistrictResourceEditorInput> EditorInputChanged { get; set; }

    [Parameter]
    public int RandomizeMin { get; set; }

    [Parameter]
    public EventCallback<int> RandomizeMinChanged { get; set; }

    [Parameter]
    public int RandomizeMax { get; set; }

    [Parameter]
    public EventCallback<int> RandomizeMaxChanged { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSaveSelectedDistrict { get; set; }

    [Parameter]
    public EventCallback<int> OnEditDistrictResources { get; set; }

    [Parameter]
    public EventCallback OnCloseDistrictEditor { get; set; }

    [Parameter]
    public EventCallback OnRandomizeResources { get; set; }

    private DistrictPreviewItem? EditingDistrict =>
        EditingDistrictId is int editingDistrictId
            ? Districts.FirstOrDefault(district => district.Id == editingDistrictId)
            : null;

    private string GetRowClass(DistrictPreviewItem district, int _)
    {
        return district.Id == SelectedDistrictId
            ? "district-preview-row-selected"
            : string.Empty;
    }

    private Task HandleRowClick(TableRowClickEventArgs<DistrictPreviewItem> args)
    {
        return args.Item is null
            ? Task.CompletedTask
            : OnDistrictSelected.InvokeAsync(args.Item.Id);
    }

    private static string FormatTriggerRadius(double? radiusMeters)
    {
        return radiusMeters.HasValue
            ? $"{radiusMeters.Value:F0}"
            : "N/A";
    }

    private Task HandleSaveSelectedDistrictAsync() => OnSaveSelectedDistrict.InvokeAsync();

    private Task HandleRandomizeResourcesAsync() => OnRandomizeResources.InvokeAsync();

    private Task HandleRandomizeMinChanged(int value) => RandomizeMinChanged.InvokeAsync(value);

    private Task HandleRandomizeMaxChanged(int value) => RandomizeMaxChanged.InvokeAsync(value);

    private Task HandleEditDistrictResourcesAsync(int districtId) => OnEditDistrictResources.InvokeAsync(districtId);

    private Task HandleCloseEditorAsync() => OnCloseDistrictEditor.InvokeAsync();

    private Task UpdateEditor(Action<DistrictResourceEditorInput> updateAction)
    {
        var nextInput = new DistrictResourceEditorInput
        {
            Gold = EditorInput.Gold,
            Voters = EditorInput.Voters,
            Likes = EditorInput.Likes,
            Oil = EditorInput.Oil,
            TriggerRadiusMeters = EditorInput.TriggerRadiusMeters
        };
        updateAction(nextInput);
        return EditorInputChanged.InvokeAsync(nextInput);
    }
}
