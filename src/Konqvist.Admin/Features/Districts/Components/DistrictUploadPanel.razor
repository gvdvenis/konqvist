@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">KML/KMZ import</MudText>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Disabled="@IsBusy"
                       OnClick="OnBackToChoices">
                Back to choices
            </MudButton>
        </MudStack>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            Upload a <b>.kml</b> or <b>.kmz</b> file. Import replaces all existing districts in this game.
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div class="district-upload-inline">
                <MudFileUpload T="IBrowserFile"
                               @bind-Files="BoundFile"
                               Accept=".kml,.kmz"
                               MaxFileSize="@MaxUploadFileSizeBytes"
                               Disabled="@IsBusy">
                    <CustomContent Context="context">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AttachFile"
                                   Disabled="@IsBusy"
                                   OnClick="@context.OpenFilePickerAsync">
                            Choose file
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
            </div>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.FileUpload"
                   Disabled="@(IsBusy || SelectedFile is null)"
                   OnClick="OnImport">
            Import districts from file
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public long MaxUploadFileSizeBytes { get; set; }

    [Parameter]
    public IBrowserFile? SelectedFile { get; set; }

    [Parameter]
    public EventCallback<IBrowserFile?> OnFileChanged { get; set; }

    [Parameter]
    public EventCallback OnBackToChoices { get; set; }

    [Parameter]
    public EventCallback OnImport { get; set; }

    private IBrowserFile? BoundFile
    {
        get => SelectedFile;
        set => _ = OnFileChanged.InvokeAsync(value);
    }
}
