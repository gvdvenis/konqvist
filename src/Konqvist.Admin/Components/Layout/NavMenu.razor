<MudStack Class="pa-4 fill-height" Spacing="3">
    <MudText Typo="Typo.h6">Konqvist Admin</MudText>
    <MudDivider />

    <MudNavMenu Dense="true">
        <MudNavLink Href="/admin/templates" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Article">Games</MudNavLink>
        <MudNavLink Href="/admin/districts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Map">Districts</MudNavLink>
        <MudNavLink Href="/admin/session" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PlayCircle">Session</MudNavLink>
    </MudNavMenu>

    <MudSpacer />
    <form method="post" action="/admin/logout">
        <AntiforgeryToken />
        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Logout"
                   FullWidth="true">
            Log out
        </MudButton>
    </form>
</MudStack>

