@using Konqvist.Admin.Features.Templates
@using Microsoft.JSInterop
@using MudBlazor

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">Existing games</MudText>
        <MudText Typo="Typo.body2" Class="admin-muted-text">@Templates.Count total</MudText>
    </MudStack>

    @if (Templates.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No games created yet.</MudAlert>
    }
    else
    {
        <MudTable Items="Templates" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Sessions</MudTh>
                <MudTh>Login token</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Sessions">@context.LinkedSessionCount</MudTd>
                <MudTd DataLabel="Login token">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudTextField T="string" Value="@context.LoginToken" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTooltip Text="Copy login token">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       OnClick="() => CopyLoginTokenAsync(context.LoginToken)">
                                <MudIcon Icon="@Icons.Material.Filled.ContentCopy" />
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Regenerate login token">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       OnClick="() => OnRegenerateLoginToken(context.Id)">
                                <MudIcon Icon="@Icons.Material.Filled.Refresh" />
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                        <MudTooltip Text="Edit game">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       OnClick="() => OnEditTemplate(context)">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" />
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Manage teams">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       Href="@($"/admin/templates/{context.Id}/teams")">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" />
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Manage rounds">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       Href="@($"/admin/templates/{context.Id}/rounds")">
                                <MudIcon Icon="@Icons.Material.Filled.Flag" />
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Manage districts">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Class="grid-square-action"
                                       Disabled="@IsBusy"
                                       Href="@($"/admin/templates/{context.Id}/districts")">
                                <MudIcon Icon="@Icons.Material.Filled.Map" />
                            </MudButton>
                        </MudTooltip>
                        <MudTooltip Text="@GetDeleteTooltip(context)">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       Class="grid-square-action"
                                       Disabled="@IsDeleteDisabled(context)"
                                       OnClick="() => HandleDeleteAsync(context.Id)">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" />
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<GameTemplateListItem> Templates { get; set; } = [];

    [Parameter, EditorRequired]
    public Func<GameTemplateListItem, Task> OnEditTemplate { get; set; } = null!;

    [Parameter, EditorRequired]
    public Func<int, Task> OnDeleteTemplate { get; set; } = null!;

    [Parameter, EditorRequired]
    public Func<int, Task> OnRegenerateLoginToken { get; set; } = null!;

    [Parameter]
    public bool IsBusy { get; set; }

    [Inject]
    private IJSRuntime JsRuntime { get; set; } = null!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = null!;

    private Task HandleDeleteAsync(int templateId) => OnDeleteTemplate(templateId);

    private bool IsDeleteDisabled(GameTemplateListItem template) => IsBusy || template.HasLinkedSessions;

    private async Task CopyLoginTokenAsync(string token)
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", token);
            Snackbar.Add("Login token copied.", Severity.Success);
        }
        catch (JSException)
        {
            Snackbar.Add("Could not copy login token.", Severity.Warning);
        }
    }

    private static string GetDeleteTooltip(GameTemplateListItem template) =>
        template.HasLinkedSessions
            ? "Delete is unavailable because this game is linked to one or more game sessions."
            : "Delete game";
}
