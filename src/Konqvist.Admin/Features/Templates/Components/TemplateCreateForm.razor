@using FluentValidation
@using Konqvist.Admin.Features.Templates
@using MudBlazor
@using System.Linq

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-3">@(_isEditMode ? "Edit game" : "Create game")</MudText>
    @if (_errors.Count > 0)
    {
        <MudAlert Severity="MudBlazor.Severity.Warning" Dense="true" Class="mb-3">
            Please fix the highlighted fields before submitting.
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudTextField T="string"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Required="true"
                          @bind-Value="_model.Name"
                          Error="@HasError(nameof(CreateGameTemplateInput.Name))"
                          ErrorText="@GetError(nameof(CreateGameTemplateInput.Name))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int"
                             Label="Total rounds"
                             Variant="Variant.Outlined"
                             Min="1"
                             Required="true"
                             @bind-Value="_model.TotalRounds"
                             Error="@HasError(nameof(CreateGameTemplateInput.TotalRounds))"
                             ErrorText="@GetError(nameof(CreateGameTemplateInput.TotalRounds))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int" Label="Location update interval (seconds)" Variant="Variant.Outlined" Min="1" Required="true" @bind-Value="_model.LocationUpdateIntervalSeconds" Error="@HasError(nameof(CreateGameTemplateInput.LocationUpdateIntervalSeconds))" ErrorText="@GetError(nameof(CreateGameTemplateInput.LocationUpdateIntervalSeconds))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int" Label="Minimum location update interval (seconds)" Variant="Variant.Outlined" Min="1" Required="true" @bind-Value="_model.MinLocationUpdateIntervalSeconds" Error="@HasError(nameof(CreateGameTemplateInput.MinLocationUpdateIntervalSeconds))" ErrorText="@GetError(nameof(CreateGameTemplateInput.MinLocationUpdateIntervalSeconds))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int" Label="Voting duration (seconds)" Variant="Variant.Outlined" Min="1" Required="true" @bind-Value="_model.VotingDurationSeconds" Error="@HasError(nameof(CreateGameTemplateInput.VotingDurationSeconds))" ErrorText="@GetError(nameof(CreateGameTemplateInput.VotingDurationSeconds))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int" Label="Prediction bonus points" Variant="Variant.Outlined" Min="0" Required="true" @bind-Value="_model.PredictionBonusPoints" Error="@HasError(nameof(CreateGameTemplateInput.PredictionBonusPoints))" ErrorText="@GetError(nameof(CreateGameTemplateInput.PredictionBonusPoints))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="int" Label="Vote timeout penalty" Variant="Variant.Outlined" Min="0" Required="true" @bind-Value="_model.VoteTimeoutPenalty" Error="@HasError(nameof(CreateGameTemplateInput.VoteTimeoutPenalty))" ErrorText="@GetError(nameof(CreateGameTemplateInput.VoteTimeoutPenalty))" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudNumericField T="double" Label="District capture radius (meters)" Variant="Variant.Outlined" Min="0.1" Required="true" @bind-Value="_model.DistrictCaptureRadiusMeters" Error="@HasError(nameof(CreateGameTemplateInput.DistrictCaptureRadiusMeters))" ErrorText="@GetError(nameof(CreateGameTemplateInput.DistrictCaptureRadiusMeters))" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(_isEditMode ? Icons.Material.Filled.Save : Icons.Material.Filled.Add)"
                   Disabled="@IsBusy"
                   OnClick="HandleSubmitAsync">
            @(_isEditMode ? "Save game" : "Create game")
        </MudButton>
        @if (_isEditMode)
        {
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Disabled="@IsBusy" OnClick="HandleCancelAsync">
                Cancel
            </MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public CreateGameTemplateInput InitialInput { get; set; } = null!;

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter, EditorRequired]
    public Func<CreateGameTemplateInput, Task<bool>> OnSubmit { get; set; } = null!;

    [Parameter, EditorRequired]
    public Func<Task> OnCancelEdit { get; set; } = null!;

    [Parameter]
    public bool IsBusy { get; set; }

    [Inject]
    private IValidator<CreateGameTemplateInput> Validator { get; set; } = null!;

    private CreateGameTemplateInput _model = new();
    private Dictionary<string, string> _errors = [];
    private bool _isEditMode;

    protected override void OnParametersSet()
    {
        _isEditMode = IsEditMode;
        _model = new CreateGameTemplateInput
        {
            Name = InitialInput.Name,
            TotalRounds = InitialInput.TotalRounds,
            LocationUpdateIntervalSeconds = InitialInput.LocationUpdateIntervalSeconds,
            MinLocationUpdateIntervalSeconds = InitialInput.MinLocationUpdateIntervalSeconds,
            VotingDurationSeconds = InitialInput.VotingDurationSeconds,
            PredictionBonusPoints = InitialInput.PredictionBonusPoints,
            VoteTimeoutPenalty = InitialInput.VoteTimeoutPenalty,
            DistrictCaptureRadiusMeters = InitialInput.DistrictCaptureRadiusMeters
        };
        _errors.Clear();
    }

    private async Task HandleSubmitAsync()
    {
        var validationResult = await Validator.ValidateAsync(_model);
        _errors = validationResult.Errors
            .GroupBy(error => error.PropertyName)
            .ToDictionary(group => group.Key, group => group.First().ErrorMessage);
        if (_errors.Count > 0)
        {
            return;
        }

        await OnSubmit(new CreateGameTemplateInput
        {
            Name = _model.Name,
            TotalRounds = _model.TotalRounds,
            LocationUpdateIntervalSeconds = _model.LocationUpdateIntervalSeconds,
            MinLocationUpdateIntervalSeconds = _model.MinLocationUpdateIntervalSeconds,
            VotingDurationSeconds = _model.VotingDurationSeconds,
            PredictionBonusPoints = _model.PredictionBonusPoints,
            VoteTimeoutPenalty = _model.VoteTimeoutPenalty,
            DistrictCaptureRadiusMeters = _model.DistrictCaptureRadiusMeters
        });
    }

    private Task HandleCancelAsync() => OnCancelEdit();

    private bool HasError(string propertyName) => _errors.ContainsKey(propertyName);

    private string? GetError(string propertyName) => _errors.GetValueOrDefault(propertyName);
}
