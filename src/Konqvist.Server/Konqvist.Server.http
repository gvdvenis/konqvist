@Konqvist.Server_HostAddress = http://localhost:5062
@GameSessionId = 1

# ── Auth ──────────────────────────────────────────────────────────────────────

# POST /api/auth/login — Bravo Runner (expect 200 + auth cookie)
POST {{Konqvist.Server_HostAddress}}/api/auth/login
Content-Type: application/json

{ "token": "BRV6X4" }

###

# POST /api/auth/login — Bravo Runner again (expect 409 runner slot in use)
POST {{Konqvist.Server_HostAddress}}/api/auth/login
Content-Type: application/json

{ "token": "BRV6X4" }

###

# GET /api/auth/me — requires auth cookie from login above (expect 200 + identity)
GET {{Konqvist.Server_HostAddress}}/api/auth/me
Accept: application/json

###

# POST /api/auth/logout — clears auth cookie (expect 204)
POST {{Konqvist.Server_HostAddress}}/api/auth/logout

###

# ── Phase navigation test flow ────────────────────────────────────────────────

# POST /api/auth/login — Bravo Team Leader (use this auth cookie for the
# session-state and phase-test requests below)
POST {{Konqvist.Server_HostAddress}}/api/auth/login
Content-Type: application/json

{ "token": "BTC53Sk" }

###

# POST /api/auth/login — Game Master (expect 200 + auth cookie)
POST {{Konqvist.Server_HostAddress}}/api/auth/login
Content-Type: application/json

{ "token": "GMzKVG" }

###

# GET /api/auth/me — Game Master identity (expect 200 + GameMaster role)
GET {{Konqvist.Server_HostAddress}}/api/auth/me
Accept: application/json

###

# GET /api/session/state — inspect the active session and confirm the current
# gameSessionId before broadcasting a phase change
GET {{Konqvist.Server_HostAddress}}/api/session/state
Accept: application/json

###

# POST /api/dev/phase-test/gathering/{gameSessionId} — development-only test
# hook for slice 4.6. Requires an authenticated caller in the same game
# session; team players and the GM are both accepted. Set @GameSessionId from
# /api/session/state.
POST {{Konqvist.Server_HostAddress}}/api/dev/phase-test/gathering/{{GameSessionId}}

###

# POST /api/dev/phase-test/reset/{gameSessionId} — development-only helper to
# rewind the current session back to Pending / WaitingForPlayers so M4 manual
# validation can be repeated from a clean pre-start state. Requires a GM cookie
# for the same game session.
POST {{Konqvist.Server_HostAddress}}/api/dev/phase-test/reset/{{GameSessionId}}

###

# POST /api/game/start — GM starts the active pending session, transitions it to
# Running/Gathering, and broadcasts the phase change to connected clients.
POST {{Konqvist.Server_HostAddress}}/api/game/start

###

# ── Other seed tokens ─────────────────────────────────────────────────────────
# Alpha Team Leader : ATCsC1a
# Bravo Runner      : BRV6X4
# Bravo Team Leader : BTC53Sk
# GM                : GMzKVG

###
